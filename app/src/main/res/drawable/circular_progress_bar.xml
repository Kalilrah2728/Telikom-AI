<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="ring" android:thickness="12dp" android:useLevel="false">
            <solid android:color="@color/all_plans_divider"/>
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <rotate android:fromDegrees="270" android:toDegrees="270">
            <shape android:shape="ring" android:thickness="12dp" android:useLevel="true">
                <solid android:color="@color/theme_blue"/>
            </shape>
        </rotate>
    </item>
</layer-list>