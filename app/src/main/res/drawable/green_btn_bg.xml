<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true"><shape>
            <solid android:color="@color/green_btn_pressed" />
            <corners android:radius="100dp" />
        </shape></item>
    <item><shape>
            <gradient android:angle="270" android:endColor="@color/green_btn_default" android:startColor="@color/green_btn_default" />
            <corners android:radius="100dp" />
        </shape></item>
</selector>